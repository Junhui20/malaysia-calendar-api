{
  "name": "@catlabtech/mycal-sdk",
  "version": "0.1.1",
  "description": "TypeScript client SDK for the Malaysia Calendar API — public holidays, school calendar, business day calculator",
  "keywords": [
    "malaysia",
    "calendar",
    "holidays",
    "cuti",
    "sdk",
    "typescript"
  ],
  "license": "MIT",
  "author": "CatLab Tech",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Junhui20/malaysia-calendar-api.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://mycal-web.pages.dev/docs/sdk/installation/",
  "bugs": {
    "url": "https://github.com/Junhui20/malaysia-calendar-api/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch"
  },
  "dependencies": {
    "@catlabtech/mycal-core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
